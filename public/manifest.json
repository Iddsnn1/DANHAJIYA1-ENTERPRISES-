  "shortcuts": [
    {
      "name": "Browse Listings",
      "short_name": "Browse",
      "description": "Browse available shelter listings",
      "url": "/?view=marketplace",
      "icons": [
        {
          "src": "/assets/icons/shortcut-browse-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "My Listings",
      "short_name": "My Listings",
      "description": "View and manage your listings",
      "url": "/?view=my-listings",
      "icons": [
        {
          "src": "/assets/icons/shortcut-listings-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  
  "prefer_related_applications": false,
  
  "pi": {
    "appId": "your_pi_app_id_here",
    "env": "testnet",
    "permissions": ["profile", "wallet"],
    "paymentAllowedMethods": ["pi_direct_payment"],
    "requiredApiVersion": "2.0"
  }
}
